# postgres credentials
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=job_processing
POSTGRES_PASSWORD=process

# JSON Web Token (JWT)
ACCESS_SECRET=          # base64 secret, generate with: openssl rand -base64 32
JWT_ISSUER=webhook
JWT_AUDIENCE=webhookuser

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_VERSION=4.2.2
RABBITMQ_HOST=localhost
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
# vhost — one of: development, staging, production
RABBITMQ_DEFAULT_VHOST=development
